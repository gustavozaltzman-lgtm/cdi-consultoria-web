---
interface FaqItem { q: string; a: string; }
interface Props { items: FaqItem[]; }
const { items } = Astro.props;
---
<div style="display:flex;flex-direction:column;gap:12px;max-width:820px">
  {items.map(item => (
    <div class="p-card">
      <h3 style="font-size:16.5px;margin-bottom:8px">{item.q}</h3>
      <p style="font-size:14px">{item.a}</p>
    </div>
  ))}
</div>
