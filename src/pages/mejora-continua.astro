---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import KpiRow from '../components/KpiRow.astro';
import Faq from '../components/Faq.astro';
import RelatedServices from '../components/RelatedServices.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { faqSchema, serviceSchema } from '../lib/schema.js';

const faqs = [
  { q: '¿Qué es la mejora continua aplicada a un depósito?', a: 'Es el proceso de revisar periódicamente indicadores operativos (exactitud, tiempos, errores) y ajustar procesos antes de que un problema se vuelva crítico, en vez de esperar a la próxima crisis para actuar.' },
  { q: '¿En qué se diferencia de una consultoría puntual?', a: 'Una consultoría puntual termina con la implementación. La mejora continua es un acompañamiento sostenido: reuniones periódicas, revisión de KPIs y ajustes de proceso a lo largo del tiempo.' },
  { q: '¿Qué pasa si dejamos de necesitar el acompañamiento?', a: 'El objetivo explícito es que el depósito funcione sin nosotros. El acompañamiento de mejora continua es opcional y se reduce en frecuencia a medida que los indicadores se sostienen solos.' },
];
---
<Layout
  title="Mejora Continua en Depósitos | CDI Consultoría"
  description="Consultoría de mejora continua: acompañamiento sostenido para que la exactitud de inventario y la eficiencia operativa no se degraden con el tiempo."
  keywords="mejora continua logística, mejora continua depósitos, acompañamiento operativo, kaizen depósito"
  jsonLd={[faqSchema(faqs), serviceSchema({ name: 'Mejora Continua', description: 'Acompañamiento sostenido con revisión periódica de KPIs para sostener las mejoras operativas en el tiempo.' })]}
>
  <Breadcrumb current="Mejora Continua" />
  <section class="hero" style="padding:48px 0 70px">
    <div class="container">
      <div class="hero-eyebrow"><span class="dot"></span> MEJORA CONTINUA</div>
      <h1 style="font-size:44px;max-width:760px">¿La mejora dura seis meses y después se pierde?</h1>
      <p class="hero-sub" style="max-width:640px">Implementar un cambio es fácil comparado con sostenerlo. Acompañamos la operación después del proyecto para que la exactitud y la eficiencia no se degraden con el tiempo.</p>
      <div class="hero-ctas"><a href="#contacto" class="btn btn-primary">Solicitar un diagnóstico</a></div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header">
        <div class="tag" style="color:var(--amber)">Problemas que resolvemos</div>
        <h2>"Todo funcionaba bien hasta hace un tiempo"</h2>
      </div>
      <div class="panel-grid g3">
        <div class="p-card warn"><h3>La exactitud vuelve a caer</h3><p>Después de un proyecto exitoso, sin seguimiento, los procesos se relajan y el desfasaje reaparece.</p></div>
        <div class="p-card warn"><h3>Rotación de personal sin transferencia</h3><p>El operador que aprendió el proceso se va, y el que entra nunca recibió la capacitación formal.</p></div>
        <div class="p-card warn"><h3>Nadie mira los indicadores</h3><p>Los KPIs se definieron una vez, pero nadie los revisa mes a mes para actuar a tiempo.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Cómo trabajamos</div><h2>Acompañamiento, no una entrega única</h2></div>
      <KpiRow items={[{n:'Mensual',l:'Revisión de KPIs'},{n:'Cíclico',l:'Refuerzo de capacitación'},{n:'6–12 meses',l:'De acompañamiento opcional'}]} />
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header"><div class="tag">Preguntas frecuentes</div><h2>Sobre mejora continua</h2></div>
      <Faq items={faqs} />
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Consultoría relacionada</div><h2>Otras líneas de trabajo</h2></div>
      <RelatedServices exclude="/mejora-continua" />
    </div>
  </section>

  <CtaBanner heading="¿Tu última mejora ya se perdió?" />
</Layout>
