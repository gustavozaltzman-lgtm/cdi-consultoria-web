---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import KpiRow from '../components/KpiRow.astro';
import Faq from '../components/Faq.astro';
import RelatedServices from '../components/RelatedServices.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { faqSchema, serviceSchema } from '../lib/schema.js';

const faqs = [
  { q: '¿Qué es la exactitud de inventario y cómo se mide?', a: 'Es el porcentaje de coincidencia entre el stock físico real y lo que indica el sistema. Se mide comparando conteos cíclicos contra el registro del ERP/WMS, SKU por SKU o por ubicación.' },
  { q: '¿Qué exactitud es "buena"?', a: 'La industria considera aceptable un 95%. Nuestros clientes con inventarios cíclicos bien implementados sostienen 99% o más, incluso en operaciones de miles de SKUs.' },
  { q: '¿La exactitud se logra solo con tecnología?', a: 'No. El código de barras y el RFID reducen el error humano, pero la exactitud se sostiene con el proceso: quién cuenta, con qué frecuencia, y cómo se investiga cada discrepancia.' },
];
---
<Layout
  title="Exactitud de Inventario | CDI Consultoría"
  description="Cómo alcanzar y sostener 99%+ de exactitud de inventario sin paralizar la operación. Consultoría de procesos y tecnología aplicada al control de stock."
  keywords="exactitud de inventario, precisión de inventario, 99% de exactitud, control de stock preciso"
  jsonLd={[faqSchema(faqs), serviceSchema({ name: 'Exactitud de Inventario', description: 'Consultoría para alcanzar y sostener alta exactitud de inventario con inventarios cíclicos y tecnología aplicada.' })]}
>
  <Breadcrumb current="Exactitud de Inventario" />
  <section class="hero" style="padding:48px 0 70px">
    <div class="container">
      <div class="hero-eyebrow"><span class="dot"></span> EXACTITUD DE INVENTARIO</div>
      <h1 style="font-size:44px;max-width:760px">Exactitud de Inventario</h1>
      <p class="hero-sub" style="max-width:640px">Cómo llegar y sostener 99%+ de precisión entre el stock físico y el sistema, sin cerrar el depósito para contarlo.</p>
      <div class="hero-ctas"><a href="#contacto" class="btn btn-primary">Solicitar diagnóstico gratuito</a></div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header">
        <div class="tag" style="color:var(--amber)">Por qué se pierde exactitud</div>
        <h2>Las causas más comunes de desfasaje</h2>
      </div>
      <div class="panel-grid g3">
        <div class="p-card warn"><h3>Carga manual con error humano</h3><p>Planillas y sistemas cargados a mano generan diferencias que se acumulan mes a mes.</p></div>
        <div class="p-card warn"><h3>Bajas y mermas no registradas</h3><p>Productos vencidos, dañados o robados que nunca se dan de baja en el sistema.</p></div>
        <div class="p-card warn"><h3>Un solo conteo al año</h3><p>Un inventario anual solo muestra una foto: entre medio, el sistema y la realidad se separan.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Resultado</div><h2>Lo que logramos con nuestros clientes</h2></div>
      <KpiRow items={[{n:'99.9%',l:'Exactitud sostenida'},{n:'Cíclico',l:'Conteo continuo'},{n:'0 días',l:'De depósito cerrado'}]} />
      <div class="case-card" style="max-width:640px">
        <div class="case-head"><div><span class="case-industry">Automotriz</span><h3>Toyota Tsusho Argentina</h3></div><span class="case-status">Trazabilidad total</span></div>
        <p class="case-problem">Inventarios en múltiples proveedores dispersos, conteos manuales con planillas de papel.</p>
        <p class="case-solution"><strong>Solución:</strong> etiquetado con código QR, escaneo con lectores portátiles y control de discrepancias.</p>
        <div class="case-result"><a href="/casos-de-exito/toyota-tsusho" style="color:var(--blue)">→ Ver caso completo</a></div>
      </div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header"><div class="tag">Preguntas frecuentes</div><h2>Sobre la exactitud de inventario</h2></div>
      <Faq items={faqs} />
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Consultoría relacionada</div><h2>Otras líneas de trabajo</h2></div>
      <RelatedServices exclude="/exactitud-inventario" />
    </div>
  </section>

  <CtaBanner heading="¿Cuál es la exactitud real de tu inventario?" sub="Agendá un diagnóstico gratuito de 30 minutos y lo medimos juntos." />
</Layout>
