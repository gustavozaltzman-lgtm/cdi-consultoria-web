---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import KpiRow from '../components/KpiRow.astro';
import Faq from '../components/Faq.astro';
import RelatedServices from '../components/RelatedServices.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { faqSchema, serviceSchema } from '../lib/schema.js';

const faqs = [
  { q: '¿Cuándo conviene RFID en vez de código de barras?', a: 'Cuando el volumen de lectura es alto y necesitás leer múltiples etiquetas sin línea de vista directa (por ejemplo, un pallet completo en un portal). Para operaciones de menor volumen, el código de barras suele ser más costo-efectivo.' },
  { q: '¿RFID reemplaza al código de barras?', a: 'No necesariamente. En la mayoría de nuestros proyectos conviven: código de barras para identificación unitaria y RFID para lectura masiva en puntos de control específicos, como recepción o despacho.' },
  { q: '¿Cuánto cuesta implementar RFID en un depósito?', a: 'Depende del volumen de etiquetas, la cantidad de puntos de lectura y el tipo de mercadería. Lo definimos recién después del relevamiento, evaluando si el volumen justifica la inversión frente al código de barras.' },
];
---
<Layout
  title="RFID en Depósitos | CDI Consultoría"
  description="RFID como herramienta de consultoría logística: trazabilidad automática de mercadería sin línea de vista, cuando el volumen de la operación lo justifica."
  keywords="RFID depósitos, RFID inventario, trazabilidad RFID, tecnología RFID logística"
  jsonLd={[faqSchema(faqs), serviceSchema({ name: 'RFID en Depósitos', description: 'Implementación de RFID para trazabilidad automática de mercadería en depósitos de alto volumen.' })]}
>
  <Breadcrumb current="RFID en Depósitos" />
  <section class="hero" style="padding:48px 0 70px">
    <div class="container">
      <div class="hero-eyebrow"><span class="dot"></span> RFID EN DEPÓSITOS</div>
      <h1 style="font-size:44px;max-width:760px">RFID en Depósitos</h1>
      <p class="hero-sub" style="max-width:640px">Trazabilidad automática sin lectura manual, cuando el volumen de tu operación lo justifica. Evaluamos si RFID es la herramienta correcta antes de recomendarla.</p>
      <div class="hero-ctas"><a href="#contacto" class="btn btn-primary">Solicitar diagnóstico gratuito</a></div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header">
        <div class="tag" style="color:var(--amber)">Cuándo tiene sentido</div>
        <h2>Señales de que RFID puede ayudarte</h2>
      </div>
      <div class="panel-grid g3">
        <div class="p-card warn"><h3>Alto volumen de lectura</h3><p>Cientos de unidades por hora que hacen inviable el escaneo unitario con código de barras.</p></div>
        <div class="p-card warn"><h3>Sin trazabilidad de piezas</h3><p>Proveedores dispersos, conteos manuales con planillas de papel y verificación visual limitada.</p></div>
        <div class="p-card warn"><h3>Puntos de control críticos</h3><p>Necesitás verificar salidas o entradas masivas sin abrir cada caja o pallet.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Resultado</div><h2>Lo que logramos con RFID/QR aplicado</h2></div>
      <KpiRow items={[{n:'Sin',l:'Línea de vista necesaria'},{n:'Masiva',l:'Lectura de mercadería'},{n:'Completa',l:'Trazabilidad de piezas'}]} />
      <div class="case-card" style="max-width:640px">
        <div class="case-head"><div><span class="case-industry">Automotriz</span><h3>Toyota Tsusho Argentina</h3></div><span class="case-status">Trazabilidad total</span></div>
        <p class="case-problem">Inventarios en múltiples proveedores dispersos, sin trazabilidad de piezas, conteos manuales.</p>
        <p class="case-solution"><strong>Solución:</strong> etiquetado con código QR de TTA y escaneo con lectores portátiles.</p>
        <div class="case-result"><a href="/casos-de-exito/toyota-tsusho" style="color:var(--blue)">→ Ver caso completo</a></div>
      </div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header"><div class="tag">Preguntas frecuentes</div><h2>Sobre RFID en depósitos</h2></div>
      <Faq items={faqs} />
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Consultoría relacionada</div><h2>Otras líneas de trabajo</h2></div>
      <RelatedServices exclude="/rfid-depositos" />
    </div>
  </section>

  <CtaBanner heading="¿RFID es lo que necesita tu operación?" sub="Agendá un diagnóstico gratuito de 30 minutos y lo evaluamos juntos, sin venderte nada de entrada." />
</Layout>
