---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import KpiRow from '../components/KpiRow.astro';
import Faq from '../components/Faq.astro';
import RelatedServices from '../components/RelatedServices.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { faqSchema, serviceSchema } from '../lib/schema.js';

const faqs = [
  { q: '¿Cómo empieza una consultoría de depósitos?', a: 'Con un relevamiento presencial: mapeamos el flujo real de mercadería, medimos tiempos de picking e identificamos cuellos de botella. Entregamos un informe con hallazgos priorizados antes de proponer ningún cambio.' },
  { q: '¿Necesito cambiar de sistema o de hardware?', a: 'No necesariamente. Muchas veces el problema es de layout y codificación de ubicaciones, no de tecnología. Recomendamos hardware o WMS solo cuando el diagnóstico lo justifica.' },
  { q: '¿Sirve para depósitos chicos?', a: 'Sí. Adaptamos el alcance al tamaño real de la operación — el objetivo es que cualquier SKU se pueda ubicar en segundos, sin importar si son 300 o 3.900 SKUs.' },
];
---
<Layout
  title="Consultoría de Depósitos | CDI Consultoría"
  description="Consultoría de depósitos: ordenamos el flujo, las ubicaciones y el layout físico para reducir errores de picking y tiempos muertos. Más de 30 años de experiencia en Argentina y Uruguay."
  keywords="consultoría de depósitos, organización de depósitos, layout de depósito, ubicaciones de rack, optimización de picking"
  jsonLd={[faqSchema(faqs), serviceSchema({ name: 'Consultoría de Depósitos', description: 'Relevamiento, diseño de ubicaciones y organización de depósitos para reducir errores de picking y tiempos muertos.' })]}
>
  <Breadcrumb current="Consultoría de Depósitos" />
  <section class="hero" style="padding:48px 0 70px">
    <div class="container">
      <div class="hero-eyebrow"><span class="dot"></span> CONSULTORÍA DE DEPÓSITOS</div>
      <h1 style="font-size:44px;max-width:760px">Consultoría de Depósitos</h1>
      <p class="hero-sub" style="max-width:640px">Ordenamos tu depósito y reducimos errores de picking, con o sin cambio de sistema. El código de barras es la herramienta que usamos cuando el diagnóstico lo justifica — no el punto de partida.</p>
      <div class="hero-ctas"><a href="#contacto" class="btn btn-primary">Solicitar diagnóstico gratuito</a></div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header">
        <div class="tag" style="color:var(--amber)">Problemas que resolvemos</div>
        <h2>"El depósito es un desorden"</h2>
        <p>Las señales más comunes de que el layout y las ubicaciones necesitan una consultoría de depósitos.</p>
      </div>
      <div class="panel-grid g3">
        <div class="p-card warn"><h3>No encuentro mercadería rápido</h3><p>Cada búsqueda de SKU depende de la memoria de un operador, no de un mapa de ubicaciones.</p></div>
        <div class="p-card warn"><h3>Cada empleado usa su propio criterio</h3><p>Sin codificación de rack, cada persona guarda la mercadería donde le parece.</p></div>
        <div class="p-card warn"><h3>El depósito no escala</h3><p>Lo que funcionaba con 300 SKUs colapsa al crecer a 2.000 sin una estructura de ubicaciones.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header">
        <div class="tag">Resultados esperables</div>
        <h2>Lo que cambia después de la consultoría</h2>
      </div>
      <KpiRow items={[{n:'-40%',l:'Tiempo de picking'},{n:'100%',l:'Ubicaciones codificadas'},{n:'Segundos',l:'Para localizar cualquier SKU'}]} />
      <div class="case-card" style="max-width:640px">
        <div class="case-head"><div><span class="case-industry">Manufactura</span><h3>San Justo Iluminación</h3></div><span class="case-status">Mapeo completo</span></div>
        <p class="case-problem">3.900 SKUs de ventas + 2.500 semielaborados, depósito sin división por zonas de proceso.</p>
        <p class="case-solution"><strong>Solución:</strong> mapeo de estanterías por sectores y codificación de ubicaciones con colectores Motorola TC21.</p>
        <div class="case-result"><a href="/casos-de-exito/san-justo-iluminacion" style="color:var(--blue)">→ Ver caso completo</a></div>
      </div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header"><div class="tag">Preguntas frecuentes</div><h2>Sobre la consultoría de depósitos</h2></div>
      <Faq items={faqs} />
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Consultoría relacionada</div><h2>Otras líneas de trabajo</h2></div>
      <RelatedServices exclude="/consultoria-depositos" />
    </div>
  </section>

  <CtaBanner heading="¿Tu depósito necesita orden?" sub="Agendá un diagnóstico gratuito de 30 minutos y te decimos, sin compromiso, qué encontraríamos en un relevamiento." />
</Layout>
