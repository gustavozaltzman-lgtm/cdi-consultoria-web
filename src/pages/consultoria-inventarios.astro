---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import KpiRow from '../components/KpiRow.astro';
import Faq from '../components/Faq.astro';
import RelatedServices from '../components/RelatedServices.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { faqSchema, serviceSchema } from '../lib/schema.js';

const faqs = [
  { q: '¿Inventario cíclico o inventario anual?', a: 'El inventario anual paraliza el depósito varios días y solo muestra una foto por año. El inventario cíclico cuenta porciones del stock de forma rotativa con colectores de datos, sin cerrar la operación, y detecta discrepancias mucho antes.' },
  { q: '¿Cuánto tarda en verse una mejora en la exactitud?', a: 'Con el esquema de conteos cíclicos implementado, la mayoría de nuestros clientes ve una mejora medible en la primera ronda de conteo, y alcanza 99%+ de exactitud sostenida dentro de los primeros meses.' },
  { q: '¿Qué hacemos si ya tenemos stock en negativo?', a: 'Relevamos el origen del desfasaje (carga manual, bajas no registradas, mermas) antes de corregir el número. Corregir sin entender la causa solo esconde el problema hasta el próximo conteo.' },
];
---
<Layout
  title="Consultoría de Inventarios | CDI Consultoría"
  description="Consultoría de inventarios: control de stock que se sostiene en el tiempo. Inventarios cíclicos con colectores de datos, hasta 99.9% de exactitud, sin paralizar el depósito."
  keywords="consultoría de inventarios, control de stock, inventario cíclico, exactitud de inventario, conteo de stock"
  jsonLd={[faqSchema(faqs), serviceSchema({ name: 'Consultoría de Inventarios', description: 'Control de stock e inventarios cíclicos con colectores de datos para sostener la exactitud en el tiempo.' })]}
>
  <Breadcrumb current="Consultoría de Inventarios" />
  <section class="hero" style="padding:48px 0 70px">
    <div class="container">
      <div class="hero-eyebrow"><span class="dot"></span> CONSULTORÍA DE INVENTARIOS</div>
      <h1 style="font-size:44px;max-width:760px">Consultoría de Inventarios</h1>
      <p class="hero-sub" style="max-width:640px">Control de stock que se sostiene en el tiempo, no solo el día del conteo. Diseñamos inventarios cíclicos con colectores de datos para que el sistema refleje la realidad todo el año.</p>
      <div class="hero-ctas"><a href="#contacto" class="btn btn-primary">Solicitar diagnóstico gratuito</a></div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header">
        <div class="tag" style="color:var(--amber)">Problemas que resolvemos</div>
        <h2>"Mi inventario nunca coincide"</h2>
      </div>
      <div class="panel-grid g3">
        <div class="p-card warn"><h3>El sistema no refleja la realidad</h3><p>Faltan unidades, sobran otras, hay productos vencidos escondidos que nadie dio de baja.</p></div>
        <div class="p-card warn"><h3>El inventario anual paraliza todo</h3><p>Cerrás el depósito 3 días y al mes siguiente los números ya no dan.</p></div>
        <div class="p-card warn"><h3>Nadie confía en el stock del sistema</h3><p>Ventas y depósito trabajan con números distintos porque ninguno confía en el ERP.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Resultados esperables</div><h2>Lo que cambia después de la consultoría</h2></div>
      <KpiRow items={[{n:'99.9%',l:'Exactitud de inventario'},{n:'0 días',l:'De depósito cerrado'},{n:'Cíclico',l:'En vez de anual'}]} />
      <div class="case-card" style="max-width:640px">
        <div class="case-head"><div><span class="case-industry">Alimentos</span><h3>Adama</h3></div><span class="case-status">Activo y estable</span></div>
        <p class="case-problem">500 toneladas/mes de movimiento, inventarios cancelados por ser inviables de forma manual.</p>
        <p class="case-solution"><strong>Solución:</strong> control por lotes, codificación de ubicaciones e inventarios cíclicos con colectores.</p>
        <div class="case-result"><a href="/casos-de-exito/adama" style="color:var(--blue)">→ Ver caso completo</a></div>
      </div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header"><div class="tag">Preguntas frecuentes</div><h2>Sobre la consultoría de inventarios</h2></div>
      <Faq items={faqs} />
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Consultoría relacionada</div><h2>Otras líneas de trabajo</h2></div>
      <RelatedServices exclude="/consultoria-inventarios" />
    </div>
  </section>

  <CtaBanner heading="¿Tu inventario nunca coincide?" sub="Agendá un diagnóstico gratuito de 30 minutos y te decimos, sin compromiso, dónde está el desfasaje." />
</Layout>
