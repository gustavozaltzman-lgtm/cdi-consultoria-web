---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Faq from '../components/Faq.astro';
import RelatedServices from '../components/RelatedServices.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { faqSchema, serviceSchema } from '../lib/schema.js';

const faqs = [
  { q: '¿La capacitación es solo para operadores de depósito?', a: 'No. Trabajamos tres niveles distintos: operadores de depósito, supervisores y responsables de sistemas, cada uno con contenido específico a su rol.' },
  { q: '¿Se puede capacitar sin haber hecho una consultoría completa?', a: 'Sí. El taller de "código de barras como herramienta de gestión" es un servicio independiente, aunque también forma parte de la etapa 6 de nuestra metodología cuando el proyecto es completo.' },
  { q: '¿Qué queda como material después del taller?', a: 'Manual de procedimientos (SOPs), certificación de los operadores participantes, y en el caso del taller de gestión, el material de la presentación.' },
];
---
<Layout
  title="Capacitación Operativa en Depósitos | CDI Consultoría"
  description="Capacitación operativa para equipos de depósito, logística y sistemas: talleres prácticos de código de barras, RFID y procedimientos de control de stock."
  keywords="capacitación operativa logística, capacitación depósito, taller código de barras, capacitación control de stock"
  jsonLd={[faqSchema(faqs), serviceSchema({ name: 'Capacitación Operativa', description: 'Talleres prácticos para operadores, supervisores y responsables de sistemas en control de stock y código de barras.' })]}
>
  <Breadcrumb current="Capacitación Operativa" />
  <section class="hero" style="padding:48px 0 60px">
    <div class="container">
      <div class="hero-eyebrow"><span class="dot"></span> CAPACITACIÓN OPERATIVA</div>
      <h1 style="font-size:44px;max-width:760px">La tecnología sola no sirve si tu equipo no la usa</h1>
      <p class="hero-sub" style="max-width:640px">Capacitamos operadores, supervisores y responsables de sistemas para que el cambio de proceso se sostenga, no dependa de una sola persona que "ya sabe cómo es".</p>
      <div class="hero-ctas"><a href="#contacto" class="btn btn-primary">Solicitar información</a></div>
    </div>
  </section>

  <section style="padding-top:0">
    <div class="container">
      <div class="method-grid">
        <div class="pipeline">
          <div class="p-step"><div class="num">4 HS</div><h4>Código de barras como herramienta de gestión</h4><p>Introducción a la tecnología, tipos de códigos, lectores, impresoras, casos prácticos del rubro. Pensado para mandos medios y dirección.</p></div>
          <div class="p-step"><div class="num">2–3 D.</div><h4>Capacitación en campo: operación de depósito</h4><p>Entrenamiento práctico con tus equipos en ingresos, ubicaciones, picking, egresos e inventarios. Cada operador certificado, con manual de SOPs entregado.</p></div>
          <div class="p-step"><div class="num">1 DÍA</div><h4>Para responsables de sistemas</h4><p>Configuración de equipos, integración con ERP, resolución de problemas comunes y mantenimiento preventivo. Para que tu equipo de IT sea autónomo.</p></div>
        </div>
        <aside class="method-visual">
          <h3>Contenido del taller de gestión</h3>
          <ul class="scope-list">
            <li><span class="ok">✓</span> Introducción al código de barras y RFID</li>
            <li><span class="ok">✓</span> Código de barras como herramienta de gestión empresarial</li>
            <li><span class="ok">✓</span> Tecnologías existentes (barras, QR, RFID)</li>
            <li><span class="ok">✓</span> Implementación paso a paso</li>
            <li><span class="ok">✓</span> Resumen general y preguntas</li>
          </ul>
          <div class="price-box">
            <div class="lbl">Inversión del taller de gestión</div>
            <div class="amt">$28.000 <span style="font-size:14px;font-weight:400;color:var(--muted)">+ IVA</span></div>
            <div class="note">4 horas · 2–3 consultores senior. Viáticos no incluidos fuera de CABA.</div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section style="background:var(--panel-2)">
    <div class="container">
      <div class="section-header"><div class="tag">Preguntas frecuentes</div><h2>Sobre capacitación operativa</h2></div>
      <Faq items={faqs} />
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header"><div class="tag">Consultoría relacionada</div><h2>Otras líneas de trabajo</h2></div>
      <RelatedServices exclude="/capacitacion-operativa" />
    </div>
  </section>

  <CtaBanner heading="¿Tu equipo necesita capacitación en control de stock?" />
</Layout>
